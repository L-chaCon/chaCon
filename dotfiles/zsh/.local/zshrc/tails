# vim: ft=zsh

alias aws-login="aws sso login --sso-session tails && aws-docker-login"
alias aws-docker-login="aws ecr get-login-password --region eu-west-1 --profile=production | docker login --username AWS --password-stdin 426105708615.dkr.ecr.eu-west-1.amazonaws.com"

alias mf="make format"
alias mt="make test"
alias mi="make install"

tails-pip () {
    CA_TOKEN=$(aws codeartifact get-authorization-token --profile production --domain tails --domain-owner 426105708615 --query authorizationToken --output text)
    INDEX_URL="https://aws:$CA_TOKEN@tails-426105708615.d.codeartifact.eu-west-1.amazonaws.com/pypi/tails/simple/"
    VENV=$(dirname $(dirname $(pyenv which python)))
    echo "[global]\nindex-url = $INDEX_URL" > $VENV/pip.conf
    printf "Added Tails pip config to use Tails PyPi for: $VENV\n"
    printf "$(cat $VENV/pip.conf)\n"
}

tails-uv () {
    CA_TOKEN=$(aws codeartifact get-authorization-token --profile production --domain tails --domain-owner 426105708615 --query authorizationToken --output text)
    INDEX_URL="https://aws:$CA_TOKEN@tails-426105708615.d.codeartifact.eu-west-1.amazonaws.com/pypi/tails/simple/"
    export UV_INDEX_URL=$INDEX_URL
    echo $UV_INDEX_URL
}

tails-poetry () {
  export POETRY_HTTP_BASIC_TAILS_USERNAME=aws
  export POETRY_HTTP_BASIC_TAILS_PASSWORD=$(cat .codeartifact-token)
  echo $POETRY_HTTP_BASIC_TAILS_USERNAME
  echo $POETRY_HTTP_BASIC_TAILS_PASSWORD
}

# ====================   STU SCRIPTS  ==================== #
list-funcs() {
  zsh -f -c '
    source ~/.local/local/zshrc/tails
    print -l ${(k)functions}
  '
}

code_location="$HOME/github.com/tails.com"

services=("tails" "adamm" "queue-service" "warehouse-service" "packing-service" 
"delivery-service" "adamm-control-panel" "adamm-bagging" "personalisation-service" 
"printables-service")

gs-all() {
  for service in $services; do
    echo "==$service=="; git -C "$code_location/$service" status
  done
}

create-tails-network() {
  docker network inspect tails-network >/dev/null 2>&1 || docker network create tails-network
}

queue-build() {
  docker exec queue-service-celery-1 /bin/sh -c "celery -A service.tasks.celery_app call queue.build"
}

cs-stop() {
 docker container stop $(docker container ls -q)
}

tidy-up() {
  cs-stop 
  docker system prune -f
}

set-title() {
  echo -ne "\033]0;$1\007"
}

develop-adamm() {
  create-tails-network

  WINDOW=$(tmux display-message -p '#S'):$(tmux display-message -p '#I')

  tmux rename-window 'deploy-adamm'
  tmux send-keys -t $WINDOW "cd $code_location/warehouse-service && make run" C-m
  tmux select-pane -t $WINDOW -T "warehouse-service"

  tmux split-window -h -t $WINDOW
  tmux send-keys -t $WINDOW.1 "cd $code_location/tails/warehouse && make run" C-m
  tmux select-pane -t $WINDOW.1 -T "tails"

  tmux split-window -h -t $WINDOW
  tmux send-keys -t $WINDOW.2 "cd $code_location/adamm && make run" C-m
  tmux select-pane -t $WINDOW.2 -T "adamm"

  tmux split-window -h -t $WINDOW
  tmux send-keys -t $WINDOW.3 "cd $code_location/queue-service && make run" C-m
  tmux select-pane -t $WINDOW.3 -T "queue-service"

  tmux split-window -h -t $WINDOW
  tmux send-keys -t $WINDOW.4 "cd $code_location/queue-service && docker compose up celery" C-m
  tmux select-pane -t $WINDOW.4 -T "queue-service-celery"

  tmux split-window -h -t $WINDOW
  tmux send-keys -t $WINDOW.5 "cd $code_location/adamm-control-panel && make run" C-m
  tmux select-pane -t $WINDOW.5 -T "adamm-control-panel"

  tmux select-layout tiled
}

